{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Augur OS",
  "version": "0.2.1",
  "identifier": "com.divyamtalwar.augur",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Augur OS",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
